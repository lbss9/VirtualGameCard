{
  "Jwt": {
    "Issuer": "virtualgamecard-api",
    "Audience": "virtualgamecard-web",
    "AccessTokenMinutes": 15
  },
  "RateLimiting": {
    "AuthPermitLimit": 10,
    "SensitivePermitLimit": 5,
    "PurchasePermitLimit": 10,
    "SupportPermitLimit": 5,
    "WebhookPermitLimit": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174",
      "http://127.0.0.1:5173",
      "http://127.0.0.1:5174"
    ]
  },
  "Metrics": {
    "Enabled": false
  },
  "Sqs": {
    "Enabled": false,
    "Region": "us-east-2",
    "PaymentRequestedQueueUrl": "",
    "PaymentApprovedQueueUrl": "",
    "WaitTimeSeconds": 20,
    "VisibilityTimeoutSeconds": 180,
    "MaxNumberOfMessages": 5,
    "PaymentProcessingDelaySeconds": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
