{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5434;Database=virtualgamecard;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Secret": "local-development-jwt-key-at-least-32-characters"
  },
  "PaymentWebhook": {
    "Secret": "local-development-webhook-secret-change-me"
  },
  "Metrics": {
    "Enabled": true
  },
  "RabbitMq": {
    "Enabled": true,
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "Exchange": "virtualgamecard.payments",
    "PaymentRequestedQueue": "payments.requested",
    "PaymentRequestedRoutingKey": "payment.requested"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
